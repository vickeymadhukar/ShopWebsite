<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bagify Admin - Create Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; color: #111; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .glass-nav { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        premium: {
                            50: '#fdfbf9',
                            100: '#f8f4ec',
                            200: '#eee5d5',
                            300: '#e1d0b6',
                            400: '#d0b691',
                            500: '#bf996b',
                            600: '#b28453',
                            700: '#956842',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col antialiased">

    <!-- Navbar -->
    <header class="glass-nav sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-2xl">👜</span>
                <h1 class="text-xl font-serif font-semibold tracking-wide text-gray-900">Bagify Admin</h1>
            </div>
            <div class="flex items-center space-x-4">
                <span class="text-sm font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-full">Admin Portal</span>
                <a href="/shop" class="text-sm font-medium text-gray-600 hover:text-black transition-colors flex items-center gap-1">
                    <span>View Store</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                </a>
            </div>
        </div>
    </header>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
    <div id="success-alert" class="fixed top-24 right-5 z-50 max-w-sm w-full bg-green-50/95 backdrop-blur-md border border-green-200 text-green-800 text-sm px-4 py-3 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center justify-between transform transition-all duration-500 translate-x-0">
        <div class="flex items-center space-x-3">
            <div class="rounded-full bg-green-100 p-1.5 shadow-sm">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <span class="font-medium"><%= success %></span>
        </div>
        <button onclick="document.getElementById('success-alert').style.display='none'" class="text-green-600 hover:text-green-800 focus:outline-none p-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
    <script>
        setTimeout(() => {
            const alert = document.getElementById('success-alert');
            if (alert) {
                alert.style.opacity = '0';
                alert.style.transform = 'translateX(100%)';
                setTimeout(() => alert.remove(), 500);
            }
        }, 4000);
    </script>
    <% } %>

    <div class="flex-grow flex flex-col lg:flex-row max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 gap-8">
        
        <!-- Sidebar -->
        <aside class="w-full lg:w-64 flex-shrink-0">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden sticky top-24">
                <div class="p-6">
                    <h3 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-4">Dashboard</h3>
                    <nav class="space-y-2">
                        <a href="/shop" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-xl transition-colors">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                            All Products
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-white bg-black rounded-xl shadow-sm transition-colors">
                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                            Create Product
                        </a>
                    </nav>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-10">
                <div class="mb-8 pb-6 border-b border-gray-100 flex items-center justify-between font-serif">
                    <div>
                        <h2 class="text-2xl font-semibold text-gray-900">Add New Product</h2>
                        <p class="text-sm text-gray-500 mt-1 font-sans">Fill in the details to list a new bag on the store.</p>
                    </div>
                    <div class="hidden sm:flex h-12 w-12 bg-premium-50 rounded-full items-center justify-center text-premium-600 text-xl">
                        ✨
                    </div>
                </div>

                <form action="/products/create" method="post" enctype="multipart/form-data" class="space-y-10">
                    
                    <!-- Basic Info Section -->
                    <section>
                        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-5 flex items-center gap-2">
                            <span class="w-6 h-6 rounded bg-gray-100 flex items-center justify-center text-xs">1</span>
                            Basic Information
                        </h3>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="md:col-span-2 space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Product Name</label>
                                <input type="text" name="name" required placeholder="e.g. Classic Leather Tote" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors" />
                            </div>

                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Category</label>
                                <select name="category" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors appearance-none cursor-pointer">
                                    <option value="" disabled selected>Select a category</option>
                                    <option value="New Collection">New Collection</option>
                                    <option value="Handbags">Handbags</option>
                                    <option value="Laptop Bags">Laptop Bags</option>
                                    <option value="Backpacks">Backpacks</option>
                                </select>
                            </div>

                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Product Image</label>
                                <div class="relative group cursor-pointer w-full">
                                    <input type="file" name="image" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                                    <div class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 border-dashed rounded-xl flex items-center justify-center gap-2 group-hover:bg-gray-100 transition-colors">
                                        <svg class="w-5 h-5 text-gray-400 group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                                        <span class="text-sm font-medium text-gray-600 group-hover:text-black transition-colors">Upload Image</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Pricing Section -->
                    <section>
                        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-5 flex items-center gap-2">
                            <span class="w-6 h-6 rounded bg-gray-100 flex items-center justify-center text-xs">2</span>
                            Pricing Details
                        </h3>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Selling Price (₹)</label>
                                <input type="number" name="price" required placeholder="1499" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Original Price (₹)</label>
                                <input type="number" name="originalPrice" required placeholder="2499" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Discount Code/Price</label>
                                <input type="text" name="discount" placeholder="Optional" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors" />
                            </div>
                        </div>
                    </section>

                    <!-- Appearance Section -->
                    <section>
                        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-5 flex items-center gap-2">
                            <span class="w-6 h-6 rounded bg-gray-100 flex items-center justify-center text-xs">3</span>
                            Appearance
                        </h3>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-1 md:col-span-2">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Description</label>
                                <textarea name="description" required placeholder="Describe the bag's material, dimensions, and style..." rows="3" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors resize-none"></textarea>
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Item Color</label>
                                <input type="text" name="color" required placeholder="e.g. Midnight Black" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-semibold text-gray-600 uppercase tracking-wider ml-1">Text Color Hex</label>
                                <input type="text" name="textcolor" placeholder="#000000" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black focus:bg-white transition-colors" />
                            </div>
                        </div>
                    </section>
                    
                    <div class="pt-6 border-t border-gray-100 flex justify-end">
                        <button type="button" class="px-6 py-3 text-sm font-medium text-gray-600 hover:text-black transition-colors mr-2">Cancel</button>
                        <button type="submit" class="bg-black text-white px-8 py-3 rounded-xl text-sm font-medium hover:bg-gray-900 transition-all shadow-[0_4px_14px_0_rgb(0,0,0,0.2)] hover:shadow-[0_6px_20px_rgba(0,0,0,0.23)] hover:-translate-y-0.5 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                            Create Product
                        </button>
                    </div>

                </form>
            </div>
        </main>

    </div>

</body>
</html>
