<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bagify - Account Settings</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #fafafa; color: #111; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .glass-nav { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        premium: {
                            50: '#fdfbf9', 100: '#f8f4ec', 200: '#eee5d5', 300: '#e1d0b6',
                            400: '#d0b691', 500: '#bf996b', 600: '#b28453', 700: '#956842',
                            800: '#7b573a', 900: '#644731', 950: '#362417',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col antialiased">
    <!-- Navigation -->
    <header class="glass-nav sticky top-0 z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <a href="/shop" class="flex items-center gap-2 group">
                <span class="text-2xl group-hover:scale-110 transition-transform">👜</span>
                <h1 class="text-2xl font-serif font-semibold tracking-wide text-gray-900 group-hover:text-premium-700 transition-colors">Bagify</h1>
            </a>
            <div class="flex items-center space-x-6">
                <!-- Back to Shop -->
                <a href="/shop" class="text-sm font-medium text-gray-500 hover:text-black transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    <span class="hidden sm:inline">Back to Shop</span>
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
        <h2 class="text-3xl font-serif text-gray-900 mb-8 border-b border-gray-100 pb-4">Account Settings</h2>
        
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 flex flex-col items-center">
            <div class="w-24 h-24 rounded-full bg-premium-100 border-2 border-premium-200 flex items-center justify-center text-premium-800 text-3xl font-serif font-medium overflow-hidden mb-6">
                <% if (typeof user !== 'undefined' && user.name) { %>
                    <%= user.name.charAt(0).toUpperCase() %>
                <% } else { %>
                    U
                <% } %>
            </div>
            
            <h3 class="text-2xl font-semibold text-gray-900 mb-1"><%= typeof user !== 'undefined' && user.name ? user.name : 'Guest' %></h3>
            <p class="text-gray-500 mb-8"><%= typeof user !== 'undefined' && user.email ? user.email : '' %></p>
            
            <div class="w-full max-w-md space-y-4">
                <div class="p-4 bg-gray-50 rounded-xl border border-gray-100 flex justify-between items-center">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Personal Information</p>
                        <p class="text-xs text-gray-500">Update your name and contact details</p>
                    </div>
                    <button class="text-sm text-gray-400 hover:text-black font-medium">Edit</button>
                </div>
                
                <div class="p-4 bg-gray-50 rounded-xl border border-gray-100 flex justify-between items-center">
                    <div>
                        <p class="text-sm font-medium text-gray-900">Password & Security</p>
                        <p class="text-xs text-gray-500">Manage your password and security settings</p>
                    </div>
                    <button class="text-sm text-gray-400 hover:text-black font-medium">Edit</button>
                </div>

                <div class="pt-8 flex justify-center">
                    <a href="/users/logout" class="inline-flex items-center justify-center px-6 py-3 bg-red-50 text-red-600 font-medium rounded-xl border border-red-100 hover:bg-red-600 hover:text-white transition-all shadow-sm gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                        Sign Out of Account
                    </a>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 mt-auto">
        <div class="max-w-7xl mx-auto px-4 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <span class="text-lg">👜</span>
                <span class="font-serif font-semibold text-gray-900">Bagify</span>
            </div>
            <p class="text-sm text-gray-500">&copy; 2026 Bagify. Premium Quality Guaranteed.</p>
        </div>
    </footer>
</body>
</html>
