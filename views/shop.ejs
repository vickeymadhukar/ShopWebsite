<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bagify - Premium Bag Collection</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #fafafa; color: #111; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .glass-nav { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.05); }
        .product-card { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .product-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px -10px rgba(0,0,0,0.08); }
        .image-overlay { transition: opacity 0.4s ease; opacity: 0; background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 100%); }
        .product-card:hover .image-overlay { opacity: 1; }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        premium: {
                            50: '#fdfbf9',
                            100: '#f8f4ec',
                            200: '#eee5d5',
                            300: '#e1d0b6',
                            400: '#d0b691',
                            500: '#bf996b',
                            600: '#b28453',
                            700: '#956842',
                            800: '#7b573a',
                            900: '#644731',
                            950: '#362417',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col antialiased">

    <!-- Navigation -->
    <header class="glass-nav sticky top-0 z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-2xl">👜</span>
                <h1 class="text-2xl font-serif font-semibold tracking-wide text-gray-900">Bagify</h1>
            </div>
            
            <div class="flex-1 max-w-xl mx-8 hidden md:block">
                <form action="/shop" method="GET" class="relative group">
                    <input
                        type="text"
                        name="search"
                        value="<%= typeof search !== 'undefined' ? search : '' %>"
                        placeholder="Discover your perfect bag..."
                        class="w-full pl-12 pr-4 py-2.5 bg-gray-50/50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:bg-white transition-all duration-300"
                    />
                    <svg class="w-5 h-5 text-gray-400 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-gray-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </form>
            </div>

            <div class="flex items-center space-x-6">
                <!-- User Profile -->
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-premium-100 border border-premium-200 flex items-center justify-center text-premium-800 font-medium overflow-hidden">
                        <% if (typeof user !== 'undefined' && user.name) { %>
                            <%= user.name.charAt(0).toUpperCase() %>
                        <% } else { %>
                            U
                        <% } %>
                    </div>
                    <a href="/settings" class="text-sm font-medium text-gray-700 hover:text-black transition-colors hidden sm:block">
                        <%= typeof user !== 'undefined' && user.name ? user.name : 'Guest' %>
                    </a>
                </div>
                
                <!-- Admin -->
                <% if (typeof user !== 'undefined' && user.isAdmin) { %>
                    <a href="/owners/admin" class="flex items-center gap-2 px-3 py-1.5 bg-black text-white text-sm font-medium rounded-md hover:bg-gray-800 transition-colors">
                        <span>Admin</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </a>
                <% } %>

                <!-- Cart -->
                <a href="/cart" class="relative group flex items-center text-gray-700 hover:text-black transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
    <div id="success-alert" class="fixed top-24 right-5 z-50 max-w-sm w-full bg-green-50/90 backdrop-blur-md border border-green-200 text-green-800 text-sm px-4 py-3 rounded-lg shadow-lg flex items-center justify-between transform transition-all duration-500 translate-x-0">
        <div class="flex items-center space-x-3">
            <div class="rounded-full bg-green-100 p-1">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <span class="font-medium"><%= success %></span>
        </div>
        <button onclick="document.getElementById('success-alert').style.display='none'" class="text-green-600 hover:text-green-800 focus:outline-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
    <script>
        setTimeout(() => {
            const alert = document.getElementById('success-alert');
            if (alert) {
                alert.style.opacity = '0';
                alert.style.transform = 'translateX(100%)';
                setTimeout(() => alert.remove(), 500);
            }
        }, 3500);
    </script>
    <% } %>

    <!-- Hero Section -->
    <section class="relative bg-premium-900 text-premium-50 overflow-hidden">
        <div class="absolute inset-0 block">
            <div class="absolute inset-0 bg-black/10"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 relative z-10">
            <div class="max-w-2xl">
                <span class="uppercase tracking-widest text-xs font-semibold text-premium-300 mb-4 block">New Arrivals</span>
                <h2 class="text-4xl lg:text-5xl font-serif mb-6 leading-tight">Elevate Your Style with Bagify</h2>
                <p class="text-lg text-premium-200 mb-8 font-light">Discover our curated collection of premium bags designed for the modern individual. Craftsmanship meets contemporary design.</p>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full flex flex-col md:flex-row gap-10">
        
        <!-- Sidebar Filters -->
        <aside class="w-full md:w-64 flex-shrink-0 space-y-10">
            <div>
                <h3 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-5">Categories</h3>
                <ul class="space-y-3">
                    <li><a href="/shop" class="flex items-center justify-between group">
                        <span class="text-sm text-gray-600 group-hover:text-black font-medium transition-colors">All Categories</span>
                    </a></li>
                    <li><a href="/shop?category=New Collection" class="flex items-center justify-between group">
                        <span class="text-sm text-gray-600 group-hover:text-black transition-colors">New Collection</span>
                    </a></li>
                    <li><a href="/shop?category=Handbags" class="flex items-center justify-between group">
                        <span class="text-sm text-gray-600 group-hover:text-black transition-colors">Handbags</span>
                    </a></li>
                    <li><a href="/shop?category=Laptop Bags" class="flex items-center justify-between group">
                        <span class="text-sm text-gray-600 group-hover:text-black transition-colors">Laptop Bags</span>
                    </a></li>
                    <li><a href="/shop?category=Backpacks" class="flex items-center justify-between group">
                        <span class="text-sm text-gray-600 group-hover:text-black transition-colors">Backpacks</span>
                    </a></li>
                </ul>
            </div>
            
            <div>
                <h3 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-5">Price Range</h3>
                <ul class="space-y-3">
                    <li>
                        <a href="#" class="flex items-center gap-3 group">
                            <div class="w-4 h-4 border border-gray-300 rounded-sm group-hover:border-black transition-colors"></div>
                            <span class="text-sm text-gray-600 group-hover:text-black transition-colors">Under ₹1000</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="flex items-center gap-3 group">
                            <div class="w-4 h-4 border border-gray-300 rounded-sm group-hover:border-black transition-colors"></div>
                            <span class="text-sm text-gray-600 group-hover:text-black transition-colors">₹1000 - ₹2000</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="flex items-center gap-3 group">
                            <div class="w-4 h-4 border border-gray-300 rounded-sm group-hover:border-black transition-colors"></div>
                            <span class="text-sm text-gray-600 group-hover:text-black transition-colors">Above ₹2000</span>
                        </a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- Product Grid -->
        <section class="flex-1">
            <div class="flex items-center justify-between mb-8 pb-4 border-b border-gray-100">
                <h2 class="text-xl font-serif text-gray-900">Collection</h2>
                <div class="text-sm text-gray-500"><%= typeof products !== 'undefined' ? products.length : 0 %> Products</div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
                <% if (typeof products !== 'undefined' && products.length > 0) { %>
                    <% products.forEach(function(product) { 
                        const discountPercent = Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100);
                    %>
                    <div class="product-card group bg-white rounded-2xl border border-gray-100/50 flex flex-col relative">
                        <!-- Image -->
                        <div class="relative w-full aspect-[4/5] rounded-t-2xl overflow-hidden bg-gray-50 flex items-center justify-center">
                            <% if (product.image) { %>
                                <img src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>" class="w-full h-full object-cover mix-blend-multiply group-hover:scale-105 transition-transform duration-700 ease-in-out" />
                            <% } else { %>
                                <span class="text-gray-400 text-4xl">👜</span>
                            <% } %>
                            <div class="image-overlay absolute inset-0 z-10"></div>
                            
                            <!-- Badges -->
                            <div class="absolute top-3 left-3 z-20 flex flex-col gap-2">
                                <% if(discountPercent > 0) { %>
                                <span class="bg-red-500 text-white text-[10px] uppercase font-bold tracking-wider py-1 px-2 rounded-sm shadow-sm">
                                    -<%= discountPercent %>%
                                </span>
                                <% } %>
                            </div>
                            
                            <!-- Quick Add -->
                            <div class="absolute bottom-4 left-0 right-0 px-4 z-20 opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                                <a href="/addtocart/<%=product._id %>" class="flex items-center justify-center w-full bg-white/95 backdrop-blur-sm text-black text-sm font-medium py-3 rounded-xl hover:bg-black hover:text-white transition-colors border border-gray-200 shadow-sm">
                                    Add to Cart
                                </a>
                            </div>
                        </div>

                        <!-- Details -->
                        <div class="p-5 flex flex-col flex-grow">
                            <div class="text-xs text-gray-400 mb-2 font-medium uppercase tracking-wider"><%= product.color %></div>
                            <h3 class="text-base font-serif text-gray-900 mb-1 leading-snug line-clamp-1"><%= product.name %></h3>
                            <p class="text-sm text-gray-500 line-clamp-2 mb-4 font-light"><%= product.description %></p>
                            
                            <div class="mt-auto pt-4 flex items-center justify-between border-t border-gray-50">
                                <div class="flex items-baseline gap-2">
                                    <span class="text-lg font-semibold text-gray-900">₹<%= product.price %></span>
                                    <% if(discountPercent > 0) { %>
                                    <span class="text-sm text-gray-400 line-through">₹<%= product.originalPrice %></span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                <% } %>
            </div>

            <% if(typeof products !== 'undefined' && products.length === 0) { %>
            <div class="text-center py-20">
                <div class="text-4xl mb-4">👜</div>
                <h3 class="text-xl font-serif text-gray-900 mb-2">No bags found</h3>
                <p class="text-gray-500">Try adjusting your search or filters to find what you're looking for.</p>
            </div>
            <% } %>

        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="md:col-span-1">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="text-xl">👜</span>
                        <h2 class="text-xl font-serif font-semibold text-gray-900">Bagify</h2>
                    </div>
                    <p class="text-sm text-gray-500 leading-relaxed max-w-xs">Crafting confidence through beautifully designed bags. Premium quality for the modern lifestyle.</p>
                </div>
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-4">Shop</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="#" class="hover:text-black transition-colors">New Arrivals</a></li>
                        <li><a href="#" class="hover:text-black transition-colors">Bestsellers</a></li>
                        <li><a href="#" class="hover:text-black transition-colors">Handbags</a></li>
                        <li><a href="#" class="hover:text-black transition-colors">Backpacks</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-4">Support</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="#" class="hover:text-black transition-colors">FAQ</a></li>
                        <li><a href="#" class="hover:text-black transition-colors">Shipping & Returns</a></li>
                        <li><a href="#" class="hover:text-black transition-colors">Contact Us</a></li>
                        <li><a href="#" class="hover:text-black transition-colors">Track Order</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-gray-900 mb-4">Newsletter</h4>
                    <p class="text-sm text-gray-500 mb-4">Subscribe to receive updates, access to exclusive deals, and more.</p>
                    <form class="flex group">
                        <input type="email" placeholder="Enter your email" class="flex-1 bg-gray-50 border border-gray-200 rounded-l-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-black focus:border-black transition-colors" />
                        <button type="button" class="bg-black text-white px-4 py-2 text-sm rounded-r-md font-medium hover:bg-gray-800 transition-colors">Subscribe</button>
                    </form>
                </div>
            </div>
            <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-4">
                <p class="text-sm text-gray-500">&copy; 2026 Bagify. All rights reserved.</p>
                <div class="flex space-x-6 text-sm text-gray-400">
                    <a href="#" class="hover:text-gray-900 transition-colors">Privacy Policy</a>
                    <a href="#" class="hover:text-gray-900 transition-colors">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>
