<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bagify - Your Cart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
        rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
            color: #111;
        }

        .font-serif {
            font-family: 'Playfair Display', serif;
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        ::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #9ca3af;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        premium: {
                            50: '#fdfbf9',
                            100: '#f8f4ec',
                            200: '#eee5d5',
                            300: '#e1d0b6',
                            400: '#d0b691',
                            500: '#bf996b',
                            600: '#b28453',
                            700: '#956842',
                            800: '#7b573a',
                            900: '#644731',
                            950: '#362417',
                        }
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen flex flex-col antialiased">

    <!-- Navigation -->
    <header class="glass-nav sticky top-0 z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <a href="/shop" class="flex items-center gap-2 group">
                <span class="text-2xl group-hover:scale-110 transition-transform">👜</span>
                <h1
                    class="text-2xl font-serif font-semibold tracking-wide text-gray-900 group-hover:text-premium-700 transition-colors">
                    Bagify</h1>
            </a>

            <div class="flex items-center space-x-6">
                <!-- User Profile -->
                <div class="flex items-center gap-3">
                    <div
                        class="w-9 h-9 rounded-full bg-premium-100 border border-premium-200 flex items-center justify-center text-premium-800 font-medium overflow-hidden">
                        <% if (typeof user !=='undefined' && user.name) { %>
                            <%= user.name.charAt(0).toUpperCase() %>
                                <% } else { %>
                                    U
                                    <% } %>
                    </div>
                    <a href="/settings" class="text-sm font-medium text-gray-700 hidden sm:block hover:text-black transition-colors">
                        <%= typeof user !=='undefined' && user.name ? user.name : 'Guest' %>
                    </a>
                </div>

                <!-- Admin -->
                <% if (typeof user !== 'undefined' && user.isAdmin) { %>
                    <a href="/owners/admin" class="flex items-center gap-2 px-3 py-1.5 bg-black text-white text-sm font-medium rounded-md hover:bg-gray-800 transition-colors">
                        <span>Admin</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </a>
                <% } %>

                <!-- Back to Shop -->
                <a href="/shop"
                    class="text-sm font-medium text-gray-500 hover:text-black transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    <span class="hidden sm:inline">Continue Shopping</span>
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">

        <div class="mb-10 text-center sm:text-left">
            <h2 class="text-3xl font-serif text-gray-900">Your Shopping Bag</h2>
            <p class="text-gray-500 mt-2 text-sm">
                <%= user.cart.length %> items in your cart
            </p>
        </div>

        <% if(user.cart.length===0) { %>
            <div class="text-center py-20 bg-white rounded-2xl border border-gray-100 shadow-sm max-w-2xl mx-auto">
                <div class="text-5xl mb-6">🛍️</div>
                <h3 class="text-2xl font-serif text-gray-900 mb-3">Your bag is empty</h3>
                <p class="text-gray-500 mb-8 max-w-sm mx-auto">Looks like you haven't added anything to your cart yet.
                    Discover our premium collection and find your perfect match.</p>
                <a href="/shop"
                    class="inline-block bg-black text-white px-8 py-3 rounded-full font-medium hover:bg-gray-800 transition-colors shadow-md">
                    Explore Collection
                </a>
            </div>
            <% } else { %>
                <div class="flex flex-col lg:flex-row gap-10">
                    <!-- Cart Items -->
                    <div class="flex-1 space-y-6">
                        <% user.cart.forEach(function(product, index){ %>
                            <div
                                class="flex flex-col sm:flex-row gap-6 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 group">

                                <!-- Product Image -->
                                <div
                                    class="w-full sm:w-32 h-40 flex-shrink-0 bg-gray-50 rounded-xl overflow-hidden relative">
                                    <% if (product.image) { %>
                                        <img src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                            class="w-full h-full object-cover mix-blend-multiply transition-transform group-hover:scale-105" />
                                        <% } else { %>
                                            <div
                                                class="w-full h-full flex items-center justify-center text-3xl text-gray-300">
                                                👜</div>
                                            <% } %>
                                </div>

                                <!-- Product Details -->
                                <div class="flex-1 flex flex-col">
                                    <div class="flex justify-between items-start mb-1">
                                        <div>
                                            <h3 class="text-lg font-serif text-gray-900 leading-snug">
                                                <%= product.name %>
                                            </h3>
                                            <p class="text-sm text-gray-500 mt-1">Authentic Bagify Collection</p>
                                        </div>
                                        <a href="/removefromcart/<%= index %>" class="text-gray-400 hover:text-red-500 transition-colors p-1 block"
                                            title="Remove Item">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </a>
                                    </div>

                                    <div class="mt-4 flex flex-wrap gap-3 items-baseline">
                                        <span class="text-xl font-semibold text-gray-900">₹<%= product.price %></span>
                                        <% if (product.originalPrice || product.price * 2) { %>
                                            <span class="text-sm line-through text-gray-400">₹<%= product.originalPrice
                                                    || product.price * 2 %></span>
                                            <span
                                                class="text-xs font-bold text-premium-600 bg-premium-50 px-2 py-1 rounded">
                                                <%= product.discount || Math.floor((1 - (product.price /
                                                    (product.originalPrice || product.price * 2))) * 100) %>% Off
                                            </span>
                                            <% } %>
                                    </div>

                                    <div class="mt-auto pt-5 flex items-center gap-6">
                                        <!-- Quantity Controls -->
                                        <div class="flex items-center gap-4 bg-gray-50 border border-gray-200 rounded-full px-1 py-1"
                                            data-price="<%= product.price %>">
                                            <button onclick="decreaseQty('<%= index %>')"
                                                class="w-8 h-8 rounded-full flex items-center justify-center text-gray-500 hover:bg-white hover:text-black hover:shadow-sm transition-all focus:outline-none">−</button>
                                            <span id="qty-<%= index %>"
                                                class="w-6 text-center text-sm font-medium">1</span>
                                            <button onclick="increaseQty('<%= index %>')"
                                                class="w-8 h-8 rounded-full flex items-center justify-center text-gray-500 hover:bg-white hover:text-black hover:shadow-sm transition-all focus:outline-none">+</button>
                                        </div>

                                        <button
                                            class="text-sm font-medium text-gray-500 hover:text-black transition-colors underline underline-offset-4 decoration-gray-300 hover:decoration-black">Save
                                            for later</button>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <!-- Order Summary -->
                    <div class="w-full lg:w-96 flex-shrink-0">
                        <div
                            class="bg-white shadow-[0_8px_30px_rgb(0,0,0,0.04)] rounded-2xl border border-gray-100 p-6 sm:p-8 sticky top-32">
                            <h2
                                class="text-lg font-serif font-semibold text-gray-900 mb-6 pb-4 border-b border-gray-100">
                                Order Summary</h2>

                            <div class="space-y-4 text-sm text-gray-600">
                                <div class="flex justify-between items-center">
                                    <span>Subtotal (<span id="total-items-summary">
                                            <%= user.cart.length %>
                                        </span> items)</span>
                                    <span class="font-medium text-gray-900">₹<span id="total-price">0</span></span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Shipping estimate</span>
                                    <span
                                        class="font-medium text-green-600 bg-green-50 px-2 py-0.5 rounded text-xs">FREE</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span>Tax estimate</span>
                                    <span class="font-medium text-gray-900">Included</span>
                                </div>
                            </div>

                            <div class="my-6 pt-6 border-t border-gray-100 flex justify-between items-baseline">
                                <span class="text-base font-medium text-gray-900">Total</span>
                                <span class="text-2xl font-serif font-semibold text-gray-900">₹<span
                                        id="amount-payable">0</span></span>
                            </div>

                            <button
                                class="w-full bg-black text-white text-base font-medium py-4 rounded-xl hover:bg-gray-800 transition-all shadow-[0_4px_14px_0_rgb(0,0,0,0.2)] hover:shadow-[0_6px_20px_rgba(0,0,0,0.23)] hover:-translate-y-0.5 mt-2 flex justify-center items-center gap-2">
                                <span>Proceed to Checkout</span>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </button>

                            <div class="mt-6 flex flex-col items-center gap-3">
                                <div class="flex gap-2">
                                    <span
                                        class="bg-gray-50 px-3 py-1.5 rounded-md text-xs font-semibold text-gray-500 border border-gray-100">SECURE
                                        PAYMENT</span>
                                    <span
                                        class="bg-gray-50 px-3 py-1.5 rounded-md text-xs font-semibold text-gray-500 border border-gray-100">FREE
                                        RETURNS</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 mt-auto">
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <span class="text-lg">👜</span>
                <span class="font-serif font-semibold text-gray-900">Bagify</span>
            </div>
            <p class="text-sm text-gray-500">&copy; 2026 Bagify. Premium Quality Guaranteed.</p>
        </div>
    </footer>

    <script>
        const productPrices = document.querySelectorAll("[data-price]");
        let total = 0;

        function updateTotal() {
            total = 0;
            productPrices.forEach((div, index) => {
                const price = parseFloat(div.dataset.price);
                const qtyElement = document.getElementById(`qty-${index}`);
                if (qtyElement) {
                    const qty = parseInt(qtyElement.innerText);
                    total += price * qty;
                }
            });

            const totalPriceEl = document.getElementById("total-price");
            const amountPayableEl = document.getElementById("amount-payable");

            if (totalPriceEl) totalPriceEl.innerText = total.toLocaleString('en-IN');
            if (amountPayableEl) amountPayableEl.innerText = total.toLocaleString('en-IN');
        }

        function increaseQty(index) {
            const qtyElement = document.getElementById(`qty-${index}`);
            if (qtyElement) {
                let qty = parseInt(qtyElement.innerText);
                qtyElement.innerText = qty + 1;
                updateTotal();
            }
        }

        function decreaseQty(index) {
            const qtyElement = document.getElementById(`qty-${index}`);
            if (qtyElement) {
                let qty = parseInt(qtyElement.innerText);
                if (qty > 1) {
                    qtyElement.innerText = qty - 1;
                    updateTotal();
                }
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', updateTotal);
    </script>
</body>

</html>